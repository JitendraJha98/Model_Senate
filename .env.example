# Primary recommended route: one OpenRouter key unlocks many models.
OPENROUTER_API_KEY=sk-or-v1-your-key

# Optional direct provider keys. Leave blank if you only use OpenRouter.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Optional app settings.
MODEL_SENATE_HOST=127.0.0.1
MODEL_SENATE_PORT=8001
FRONTEND_ORIGIN=http://localhost:5173

# Model Council settings.
ORCHESTRATOR_MODEL_ID=openrouter-gpt-5-2
ORCHESTRATOR_PROVIDER=openrouter
COUNCIL_MIN_MODELS=2
COUNCIL_SYNTHESIS_RETRY_ON_FAILURE=true

# Optional tools. Disabled by default.
TOOL_WEB_SEARCH_ENABLED=false
TOOL_WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
TOOL_CODE_EXECUTOR_ENABLED=false
TOOL_CODE_EXECUTOR_TIMEOUT_SECONDS=10
